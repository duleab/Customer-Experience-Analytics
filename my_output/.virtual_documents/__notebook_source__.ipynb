        ROUND(AVG(r.rating), 2)                                           AS avg_rating,
        ROUND(AVG(r.sentiment_score), 3)                                  AS avg_confidence
    FROM reviews r
    JOIN banks b USING (bank_id)
    WHERE r.sentiment_label != ''
    GROUP BY b.bank_name, r.sentiment_label
